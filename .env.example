# Modal.com credentials (from `modal token new`)
MODAL_TOKEN_ID=ak-xxxxxxxxxxxxxxxxxxxxxxxx
MODAL_TOKEN_SECRET=as-xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 storage (only needed for converter — workers load from HF Hub directly)
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=ai-model-weights

# Worker API key (set on Modal dashboard as "worker-api-key" secret)
WORKER_API_KEY=your-secret-key
